APP_ENVIRONMENT=development
APP_DATABASE_URL=postgresql+psycopg://cryptbot:change-me@db:5432/cryptbot
APP_PAPER_TRADING=true
APP_LIVE_TRADING=false
APP_LIVE_CONFIRMATION=
# Never grant withdrawal permission. Exchange-specific secrets are optional and read only here.
APP_EXCHANGE_API_KEY=
APP_EXCHANGE_API_SECRET=
# Optional. Leave empty to disable all outbound Discord notifications.
APP_PAPER__DISCORD_WEBHOOK_URL=
# Phase 9 safety interlocks. These defaults cannot enable live execution.
APP_LIVE__ENABLED=false
APP_LIVE__ADAPTER_NAME=disabled
# A second runtime confirmation is never stored in .env.
